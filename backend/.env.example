# ============ App ============
APP_NAME=Employee Report System
FRONTEND_URL=http://localhost:5173

# ============ Security / JWT ============
SECRET_KEY=please-change-this-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============ Database ============
# Option A — MySQL (project default). Make sure the DB exists:
#   CREATE DATABASE employee_db_report;
MYSQL_USER=root
MYSQL_PASSWORD=Viswanath@123
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=employee_db_report
# Option B — full URL (takes precedence if set). Handy for quick local testing:
# DATABASE_URL=sqlite:///./employee_report.db

# ============ CORS ============
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ============ Uploads ============
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=10

# ============ Deadline / working day ============
DEFAULT_DEADLINE=20:00
WORK_DAY_START=09:00
WORK_DAY_END=21:00
DEFAULT_MANAGER_CODE=MANAGER-2024

# ============ Bootstrap admin (created on first run) ============
ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@company.com
ADMIN_PASSWORD=Admin@123

# ============ Email (optional — leave disabled for local dev) ============
EMAIL_ENABLED=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@company.com
MAIL_FROM_NAME=Employee Report System
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# ============ Provisioning / Gmail SMTP (Phase 2) ============
GMAIL_ADDRESS=suddapallivviswanath@gmail.com
# 16-char App Password: Google Account -> Security -> App passwords (NOT your login password)
GMAIL_APP_PASSWORD=
ADMIN_CONTACT_EMAIL=suddapallivviswanath@gmail.com
